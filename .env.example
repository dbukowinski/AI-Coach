# Skopiuj ten plik jako .env i uzupełnij klucze:
#   cp .env.example .env
# Plik .env jest w .gitignore — nie trafi do repozytorium.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Wybierz providera: groq | anthropic | openai
AI_PROVIDER=groq

# Groq — darmowy, szybki, open source (llama-3.3-70b-versatile)
# Klucz: https://console.groq.com → API Keys
GROQ_API_KEY=tu_wklej_klucz

# Anthropic Claude (opcjonalnie)
# Klucz: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=tu_wklej_klucz_opcjonalnie

# OpenAI (opcjonalnie)
# Klucz: https://platform.openai.com → API Keys
OPENAI_API_KEY=tu_wklej_klucz_opcjonalnie

# ── AWS Bedrock (legacy — obecnie nieużywany) ─────────────────────────────────
AWS_REGION=eu-central-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v1:0

# ── Strava OAuth ──────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
APP_URL=
